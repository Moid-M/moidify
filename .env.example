# Moidify environment configuration
# Copy this file to .env and adjust values

# Server port (default: 8000)
MOIDIFY_PORT=8000

# Paths (defaults are relative to the project directory)
MOIDIFY_MUSIC_DIR=./music
MOIDIFY_COVERS_DIR=./covers
MOIDIFY_DB_PATH=./data/music.db

# Max upload size in bytes (default: 2.5 GB)
MOIDIFY_MAX_UPLOAD_SIZE=2684354560
