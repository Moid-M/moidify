#!/usr/bin/env bash
set -euo pipefail

APP_DIR="/opt/moidify"
DATA_DIR="/var/lib/moidify"
CONFIG_DIR="/etc/moidify"
SERVICE="moidify"
SERVICE_FILE="/etc/systemd/system/${SERVICE}.service"
SERVER_HOST="0.0.0.0"
SERVER_PORT=""
if [[ -f "$CONFIG_DIR/config.json" ]]; then
  SERVER_PORT=$(python3 -c "import json; print(json.load(open('$CONFIG_DIR/config.json')).get('port','8000'))" 2>/dev/null || echo "8000")
else
  SERVER_PORT="8000"
fi

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

info()  { echo -e "${CYAN}::${NC} $1"; }
ok()    { echo -e "${GREEN}ok${NC}  $1"; }
warn()  { echo -e "${YELLOW}!!${NC} $1"; }
err()   { echo -e "${RED}!!${NC} $1"; }

version() {
  if [[ -f "$APP_DIR/version.txt" ]]; then
    cat "$APP_DIR/version.txt"
  else
    echo "unknown"
  fi
}

help() {
  APP_VER=$(version 2>/dev/null || echo "?")
  echo -e "${BOLD}Moidify v${APP_VER}${NC} — Self-hosted music server"
  echo ""
  echo -e "${BOLD}Usage:${NC}"
  echo -e "  moidify ${CYAN}<command>${NC} [options]"
  echo ""
  echo -e "${BOLD}Service commands:${NC}"
  echo -e "  ${GREEN}start${NC}     Start moidify service"
  echo -e "  ${GREEN}stop${NC}      Stop moidify service"
  echo -e "  ${GREEN}restart${NC}   Restart moidify service"
  echo -e "  ${GREEN}status${NC}    Show service status"
  echo -e "  ${GREEN}enable${NC}    Enable service on boot"
  echo -e "  ${GREEN}disable${NC}   Disable service on boot"
  echo ""
  echo -e "${BOLD}Info commands:${NC}"
  echo -e "  ${GREEN}logs${NC}      Follow service logs (Ctrl+C to exit)"
  echo -e "  ${GREEN}config${NC}    Show current configuration"
  echo -e "  ${GREEN}version${NC}   Show installed version"
  echo -e "  ${GREEN}url${NC}       Show server URL"
  echo ""
  echo -e "${BOLD}Maintenance:${NC}"
  echo -e "  ${GREEN}reload${NC}    Reload (restart) service"
  echo -e "  ${GREEN}update${NC}    Run update script"
  echo ""
  echo -e "${BOLD}Options:${NC}"
  echo -e "  ${GREEN}-h, --help${NC}     Show this help"
  echo -e "  ${GREEN}-v, --version${NC}  Show version"
  echo ""
  echo -e "${BOLD}Examples:${NC}"
  echo -e "  moidify start"
  echo -e "  moidify logs"
  echo -e "  moidify config"
}

url() {
  local ip port="${SERVER_PORT}"
  ip=$(ip route get 1 2>/dev/null | awk '{print $7}' || hostname -I 2>/dev/null | awk '{print $1}' || echo "localhost")
  echo "http://${ip}:${port}"
}

show_config() {
  if [[ ! -f "$CONFIG_DIR/config.json" ]]; then
    err "Config file not found at $CONFIG_DIR/config.json"
    exit 1
  fi
  echo -e "${BOLD}Configuration:${NC}"
  echo "  Config file: $CONFIG_DIR/config.json"
  echo "  Data dir:    $DATA_DIR"
  echo "  App dir:     $APP_DIR"
  # Use Python to pretty-print JSON config
  python3 -c "
import json
with open('$CONFIG_DIR/config.json') as f:
    cfg = json.load(f)
for k, v in cfg.items():
    print(f'  {k}: {v}')
" 2>/dev/null || cat "$CONFIG_DIR/config.json"
  echo ""
  echo -e "${YELLOW}URL:${NC} $(url)"
}

# ─── Parse args ───────────────────────────────────────────────────────────────

case "${1:-}" in
  -h|--help|-help|help)
    help
    exit 0
    ;;
  -v|--version|version)
    echo "Moidify $(version)"
    exit 0
    ;;
  start)
    info "Starting moidify..."
    systemctl start "$SERVICE" 2>/dev/null || {
      warn "Systemd not available; starting directly..."
      if [[ -f "$APP_DIR/server.py" ]]; then
        cd "$APP_DIR"
        nohup "$APP_DIR/venv/bin/uvicorn" server:app --host "$SERVER_HOST" --port "$SERVER_PORT" > /tmp/moidify.log 2>&1 &
        disown
        info "Server PID: $!"
      else
        err "App not found at $APP_DIR"
        exit 1
      fi
    }
    sleep 1
    if systemctl is-active --quiet "$SERVICE" 2>/dev/null || pgrep -f "uvicorn.*server:app" >/dev/null 2>&1; then
      ok "Moidify is running → $(url)"
    else
      warn "Check logs: moidify logs"
    fi
    ;;
  stop)
    info "Stopping moidify..."
    if systemctl stop "$SERVICE" 2>/dev/null; then
      ok "Moidify stopped."
    else
      pkill -f "uvicorn.*server:app" 2>/dev/null && ok "Moidify stopped." || warn "No running process found."
    fi
    ;;
  restart|reload)
    info "Restarting moidify..."
    if systemctl restart "$SERVICE" 2>/dev/null; then
      sleep 1
      if systemctl is-active --quiet "$SERVICE" 2>/dev/null; then
        ok "Moidify restarted → $(url)"
      else
        warn "Check logs: moidify logs"
      fi
    else
      pkill -f "uvicorn.*server:app" 2>/dev/null || true
      if [[ -f "$APP_DIR/server.py" ]]; then
        cd "$APP_DIR"
        nohup "$APP_DIR/venv/bin/uvicorn" server:app --host "$SERVER_HOST" --port "$SERVER_PORT" > /tmp/moidify.log 2>&1 &
        disown
        sleep 1
        ok "Moidify restarted → $(url)"
      fi
    fi
    ;;
  status)
    if systemctl status "$SERVICE" 2>/dev/null; then
      exit 0
    fi
    if pgrep -f "uvicorn.*server:app" >/dev/null 2>&1; then
      echo -e "${GREEN}●${NC} Moidify is running"
      echo "   $(url)"
    else
      echo -e "${RED}●${NC} Moidify is not running"
    fi
    ;;
  enable)
    systemctl enable "$SERVICE" 2>/dev/null && ok "Service enabled on boot." || err "Failed to enable service."
    ;;
  disable)
    systemctl disable "$SERVICE" 2>/dev/null && ok "Service disabled on boot." || err "Failed to disable service."
    ;;
  logs)
    if command -v journalctl &>/dev/null && systemctl is-active --quiet "$SERVICE" 2>/dev/null; then
      exec journalctl -u "$SERVICE" -f -n 30 --no-pager
    else
      exec tail -f /tmp/moidify.log 2>/dev/null || err "No log file found."
    fi
    ;;
  config)
    show_config
    ;;
  url)
    echo "$(url)"
    ;;
  update)
    if [[ -f "$APP_DIR/update.sh" ]]; then
      exec "$APP_DIR/update.sh"
    else
      err "Update script not found at $APP_DIR/update.sh"
      exit 1
    fi
    ;;
  "")
    err "No command specified."
    echo ""
    help
    exit 1
    ;;
  *)
    err "Unknown command: ${1}"
    echo ""
    help
    exit 1
    ;;
esac
